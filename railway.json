{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/Dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/health.php",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "preDeployCommand": "php scripts/init-db.php"
  }
}
